# ─── Live quotes (Finnhub) ─────────────────────────────────────────────────
# Required for live last prices and benchmark history in the position monitor.
# Sign up: https://finnhub.io/register
#
# Local: copy this file to `.env.local` and paste your key.
# Vercel: Project → Settings → Environment Variables → add for Production + Preview.
#
# The key is read only on the server (`src/lib/finnhub.ts`, `src/app/api/quotes/route.ts`).
# It is never sent to the browser.

FINNHUB_API_KEY=
